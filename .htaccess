RewriteEngine On
RewriteRule ^(.*)\.html$ $1.php [L]
RewriteRule ^product/([a-zA-Z0-9_-]+)$ product.php?name=$1 [L,QSA]

# Block direct browser access to chatbot config and lead log
<Files "chatbot-config.php">
    Order allow,deny
    Deny from all
</Files>
<Files "chatbot-leads.log">
    Order allow,deny
    Deny from all
</Files>

